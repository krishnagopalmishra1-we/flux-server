# ==============================================================
# Neural Creation Studio — Multi-Modal AI Generation Platform
# Environment Configuration Template (.env.example)
# Copy this to .env and customize for your deployment
# ==============================================================

# ─────────────────────────────────────────────────────────────
# HuggingFace & Model Loading
# ─────────────────────────────────────────────────────────────
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Separate token for gated models (e.g., Stable Diffusion 3)
SD3_HF_TOKEN=

# Model defaults
MODEL_ID=black-forest-labs/FLUX.1-dev
CACHE_DIR=/mnt/hf-cache
HF_HOME=/mnt/hf-cache
TRANSFORMERS_CACHE=/mnt/hf-cache

# ─────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
WORKERS=1

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=10

# ─────────────────────────────────────────────────────────────
# Image Generation
# ─────────────────────────────────────────────────────────────
DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
MAX_WIDTH=2048
MAX_HEIGHT=2048
DEFAULT_STEPS=28
DEFAULT_GUIDANCE_SCALE=3.5

# ─────────────────────────────────────────────────────────────
# Video Generation (Wan 2.1 / ACE-Step)
# ─────────────────────────────────────────────────────────────
ENABLE_VIDEO=true
WAN_DEFAULT_VARIANT=1.3b
# Options: "1.3b" (fast, ~2GB VRAM) or "14b" (slower, ~40GB VRAM)
DEFAULT_VIDEO_FPS=16
DEFAULT_VIDEO_FRAMES=33
DEFAULT_VIDEO_DURATION=2

# ─────────────────────────────────────────────────────────────
# Music Generation (MusicGen, AudioGen, Udio)
# ─────────────────────────────────────────────────────────────
ENABLE_MUSIC=true
DEFAULT_MUSIC_DURATION=30
DEFAULT_MUSIC_SAMPLE_RATE=16000

# ─────────────────────────────────────────────────────────────
# Animation & Talking Head (LivePortrait, SadTalker)
# ─────────────────────────────────────────────────────────────
ENABLE_ANIMATION=true
DEFAULT_ANIMATION_EXPRESSION_SCALE=1.0
DEFAULT_ANIMATION_USE_ENHANCER=false
DEFAULT_ANIMATION_POSE_STYLE=0

# ─────────────────────────────────────────────────────────────
# Output Storage & Cleanup
# ─────────────────────────────────────────────────────────────
OUTPUT_DIR=/mnt/outputs
OUTPUT_TTL_HOURS=24
# Set to 0 to keep outputs indefinitely

# ─────────────────────────────────────────────────────────────
# Job Queue Configuration
# ─────────────────────────────────────────────────────────────
MAX_QUEUE_SIZE=50
MAX_JOBS_PER_USER=5
JOB_TIMEOUT_SECONDS=1800

# ─────────────────────────────────────────────────────────────
# API Security
# ─────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys (leave empty for no auth in dev)
API_KEYS=your-secret-key-1,your-secret-key-2

# ─────────────────────────────────────────────────────────────
# Logging & Debugging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: debug, info, warning, error, critical

# ─────────────────────────────────────────────────────────────
# GCP Deployment (if using Cloud Run / Compute Engine)
# ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
