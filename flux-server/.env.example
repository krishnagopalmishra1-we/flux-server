# ==============================================
# Multi-Model Inference Server Configuration
# ==============================================
# Copy this file to .env and fill in the values

# Hugging Face token (required for FLUX.1-dev gated model)
# Get yours free at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# API keys for authentication (comma-separated)
# Leave empty for open access (not recommended for production)
API_KEYS=your-secret-key-1,your-secret-key-2

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# Model settings (defaults are fine for most cases)
# MODEL_ID is optional in multi-model mode; default model loads at startup.
# MODEL_ID=black-forest-labs/FLUX.1-dev
# CACHE_DIR=/mnt/hf-cache

# Runtime
PORT=8080
WORKERS=1
