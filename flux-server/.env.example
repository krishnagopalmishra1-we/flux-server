# ═════════════════════════════════════════════════════════════════
# Neural Creation Studio — Multi-Modal Configuration
# ═════════════════════════════════════════════════════════════════
# Copy to .env and fill in the values
# Sensible defaults are provided for most settings

# ─────────────────────────────────────────────────────────────────
# AUTHENTICATION & SECURITY
# ─────────────────────────────────────────────────────────────────

# Hugging Face token (required for FLUX.1-dev gated model)
# Get yours free at: https://huggingface.co/settings/tokens
HF_TOKEN=

# API keys for authentication (comma-separated)
# Leave empty for open access (not recommended for production)
API_KEYS=

# Admin API key for privileged endpoints (queue drain, etc.)
# Set a strong random key for production.
ADMIN_API_KEY=

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=10

# CORS allowed origins (comma-separated, or "*" for dev)
# Example: CORS_ORIGINS=https://your-frontend.com,https://staging.example.com
CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────────
# PATHS & STORAGE
# ─────────────────────────────────────────────────────────────────

# Hugging Face model cache (HDD fallback)
CACHE_DIR=/mnt/hf-cache

# SSD-tier cache for priority models (FLUX, WAN 1.3B, HunyuanVideo)
# Set same as CACHE_DIR to disable split caching.
CACHE_DIR_SSD=/app/model_cache

# Generated outputs directory (video files)
OUTPUT_DIR=/mnt/outputs

# Auto-cleanup: delete generated files after N hours (0 = disable)
OUTPUT_TTL_HOURS=24

# Persistent LoRA adapter directories. Keep these on mounted persistent storage;
# relative /app folders can disappear or point at the wrong host directory after rebuilds.
LORA_DIR=/mnt/hf-cache/loras
VIDEO_LORA_DIR=/mnt/hf-cache/video_loras
MAX_LORA_UPLOAD_MB=1536

# ─────────────────────────────────────────────────────────────────
# RUNTIME SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8080
WORKERS=1  # 1 worker per GPU (all models share single VRAM)

# ─────────────────────────────────────────────────────────────────
# IMAGE GENERATION
# ─────────────────────────────────────────────────────────────────

DEFAULT_WIDTH=1024
DEFAULT_HEIGHT=1024
DEFAULT_STEPS=28
DEFAULT_GUIDANCE_SCALE=3.5

MAX_WIDTH=2048
MAX_HEIGHT=2048

# ─────────────────────────────────────────────────────────────────
# VIDEO GENERATION
# ─────────────────────────────────────────────────────────────────

ENABLE_VIDEO=true

# Default Wan model variant: "1.3b" (fast) or "14b" (best quality)
WAN_DEFAULT_VARIANT=1.3b

# Video defaults
DEFAULT_VIDEO_FPS=16
DEFAULT_VIDEO_FRAMES=33  # ~2 seconds at 16 fps

# ─────────────────────────────────────────────────────────────────
# JOB QUEUE MANAGEMENT
# ─────────────────────────────────────────────────────────────────

# Max jobs in queue
MAX_QUEUE_SIZE=50

# Max concurrent jobs per user
MAX_JOBS_PER_USER=5

# ─────────────────────────────────────────────────────────────────
# OFFLINE MODE
# ─────────────────────────────────────────────────────────────────

# Set to true after first cache fill to skip HF network checks.
# Eliminates ~2-30s network overhead per model load.
HF_OFFLINE=false
